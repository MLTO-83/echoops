generator client {
  provider      = "prisma-client-js"
  output        = "./app/generated/prisma/client"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LicenseType {
  FREE
  BASIC
  AI_AGENT
}

model User {
  id              String            @id @default(cuid())
  name            String?
  email           String?           @unique
  emailVerified   DateTime?
  image           String?
  organizationId  String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  theme           String            @default("dark")
  adoUserId       String?           @unique
  maxHoursPerWeek Float             @default(40)
  licenseType     LicenseType       @default(FREE)
  aiAgentSettings AIAgentSettings[]
  accounts        Account[]
  authenticators  Authenticator[]
  projectMembers  ProjectMember[]
  sessions        Session[]
  organization    Organization?     @relation(fields: [organizationId], references: [id])
}

model Organization {
  id                 String               @id @default(cuid())
  name               String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  adoConnection      ADOConnection?
  aiProviderSettings AIProviderSettings[]
  programTypes       ProgramType[]
  users              User[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Authenticator {
  id           String @id @default(cuid())
  userId       String
  credentialID String @unique
  credential   String
  counter      Int
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ADOConnection {
  id                 String       @id @default(cuid())
  organizationId     String       @unique
  adoOrganizationUrl String
  pat                String
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  organization       Organization @relation(fields: [organizationId], references: [id])
  projects           Project[]
}

model ProgramType {
  id             String               @id @default(cuid())
  name           String
  description    String?
  organizationId String
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @default(now())
  organization   Organization         @relation(fields: [organizationId], references: [id])
  projects       ProjectProgramType[]

  @@unique([organizationId, name])
}

model Project {
  id              String               @id @default(cuid())
  name            String
  adoProjectId    String?
  adoConnectionId String?
  stateId         String               @default("new")
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @default(now())
  sprints         ADOSprint[]
  aiAgentJobs     AIAgentJob[]
  adoConnection   ADOConnection?       @relation(fields: [adoConnectionId], references: [id])
  members         ProjectMember[]
  programTypes    ProjectProgramType[]
  webhookConfig   ProjectWebhookConfig?
  state           State                @relation(fields: [stateId], references: [id], onDelete: Restrict)
}

model ProjectProgramType {
  projectId     String
  programTypeId String
  createdAt     DateTime    @default(now())
  programType   ProgramType @relation(fields: [programTypeId], references: [id], onDelete: Cascade)
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, programTypeId])
}

model ProjectMember {
  id          String                     @id @default(cuid())
  userId      String
  projectId   String
  role        String                     @default("OWNER")
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  project     Project                    @relation(fields: [projectId], references: [id])
  user        User                       @relation(fields: [userId], references: [id])
  weeklyHours ProjectMemberWeeklyHours[]

  @@unique([userId, projectId])
}

model ProjectMemberWeeklyHours {
  id              String        @id @default(cuid())
  projectMemberId String
  year            Int
  weekNumber      Int
  hours           Float         @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  projectMember   ProjectMember @relation(fields: [projectMemberId], references: [id], onDelete: Cascade)

  @@unique([projectMemberId, year, weekNumber])
  @@index([projectMemberId])
  @@index([year, weekNumber])
}

model ADOSprint {
  id             String        @id @default(cuid())
  projectId      String
  adoIterationId String
  name           String
  startDate      DateTime
  endDate        DateTime
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  project        Project       @relation(fields: [projectId], references: [id])
  workItems      ADOWorkItem[]

  @@unique([projectId, adoIterationId])
}

model ADOWorkItem {
  id               String    @id @default(cuid())
  adoSprintId      String
  adoWorkItemId    String
  title            String
  type             String
  state            String
  assignedTo       String?
  description      String?
  acceptanceCriteria String? @db.Text  // Added field for storing acceptance criteria
  storyPoints      Float?
  priority         Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  adoSprint        ADOSprint @relation(fields: [adoSprintId], references: [id])

  @@unique([adoSprintId, adoWorkItemId])
}

model AIProviderSettings {
  id             String       @id @default(cuid())
  organizationId String
  provider       String
  apiKey         String
  model          String
  temperature    Float        @default(0.7)
  maxTokens      Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, provider])
}

model AIAgentSettings {
  id        String   @id @default(cuid())
  userId    String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model AIAgentJob {
  id               String   @id @default(cuid())
  projectId        String
  prompt           String
  repositoryName   String
  status           String   @default("PENDING")
  pullRequestUrl   String?
  errorMessage     String?
  adoWorkItemId    String?
  adoWorkItemTitle String?
  adoWorkItemType  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  project          Project  @relation(fields: [projectId], references: [id])
}

model ProjectWebhookConfig {
  id               String   @id @default(cuid())
  projectId        String   @unique
  secret           String
  active           Boolean  @default(false)
  agentInstructions String?  @db.Text       // Added field for agent instructions
  repositoryName    String?                 // Added field for target repository
  description      String?  @db.Text        // Optional description field
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model State {
  id          String    @id
  name        String    @unique
  description String?
  projects    Project[]
}
